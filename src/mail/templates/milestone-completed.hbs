<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Congratulations! — TektonX</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" bgcolor="#f4f4f5" style="background-color:#f4f4f5;">
    <tr><td align="center" style="padding:40px 20px;">

      <table width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;background-color:#ffffff;border-radius:8px;overflow:hidden;">

        <!-- HEADER -->
        <tr>
          <td align="center" bgcolor="#0f172a" style="background-color:#0f172a;padding:28px 40px;">
            <img src="{{frontendUrl}}/logo-white-horizontal.svg" alt="TektonX" width="180" style="display:block;height:auto;" />
          </td>
        </tr>

        <!-- HERO -->
        <tr>
          <td align="center" bgcolor="#0ea5e9" style="background-color:#0ea5e9;padding:32px 40px;">
            <p style="font-size:48px;margin:0;line-height:1;">&#127881;</p>
            <h2 style="color:#ffffff;margin:12px 0 0;font-size:22px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">Program Complete!</h2>
          </td>
        </tr>

        <!-- BODY -->
        <tr>
          <td style="padding:40px;background-color:#ffffff;">
            <p style="color:#475569;line-height:1.6;margin:12px 0;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">Congratulations, <strong>{{name}}</strong>!</p>
            <p style="color:#475569;line-height:1.6;margin:12px 0;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">You've completed the TektonX mentorship program.</p>
            <span style="display:inline-block;padding:6px 14px;background-color:#ede9fe;color:#5b21b6;border-radius:20px;font-size:13px;font-weight:600;margin:8px 0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">{{track}} Track</span>
            <p style="color:#475569;line-height:1.6;margin:12px 0;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">This is a huge achievement and a testament to your dedication and hard work. Your certificate of completion is ready to download from your dashboard.</p>

            <a href="{{dashboardUrl}}" style="display:inline-block;margin:20px 0 8px;padding:12px 28px;background-color:#0ea5e9;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:600;font-size:15px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">View My Certificate</a>

            <p style="color:#475569;line-height:1.6;margin:12px 0;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">We're proud of how far you've come. Stay connected with the TektonX community — you're now part of our alumni network.</p>
          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td align="center" bgcolor="#f8fafc" style="background-color:#f8fafc;padding:20px 40px;">
            <p style="color:#94a3b8;font-size:12px;margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">&copy; {{year}} TektonX Labs. All rights reserved.</p>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
