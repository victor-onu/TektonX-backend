<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>You're Invited to TektonX</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" bgcolor="#f4f4f5" style="background-color:#f4f4f5;">
    <tr><td align="center" style="padding:40px 20px;">

      <table width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;background-color:#ffffff;border-radius:8px;overflow:hidden;">

        <!-- HEADER -->
        <tr>
          <td align="center" bgcolor="#0f172a" style="background-color:#0f172a;padding:28px 40px;">
            <img src="{{frontendUrl}}/logo-white-horizontal.svg" alt="TektonX" width="180" style="display:block;height:auto;" />
          </td>
        </tr>

        <!-- HERO -->
        <tr>
          <td align="center" bgcolor="#7c3aed" style="background-color:#7c3aed;padding:24px 40px;">
            <p style="color:#ede9fe;margin:0;font-size:15px;font-weight:500;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">You've been personally selected to join the TektonX mentorship program.</p>
          </td>
        </tr>

        <!-- BODY -->
        <tr>
          <td style="padding:40px;background-color:#ffffff;">
            <h2 style="color:#0f172a;margin:0 0 8px 0;font-size:20px;font-weight:700;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">Welcome, {{name}}!</h2>
            <span style="display:inline-block;padding:6px 14px;background-color:#ede9fe;color:#5b21b6;border-radius:20px;font-size:13px;font-weight:600;margin:8px 0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">Invited</span>
            <p style="color:#475569;line-height:1.6;margin:12px 0;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">You've been invited to join TektonX as a mentee. Click the button below to set your password and activate your account.</p>

            <table width="100%" cellpadding="0" cellspacing="0" style="margin:16px 0;">
              <tr><td bgcolor="#fef9c3" style="background-color:#fef9c3;border:1px solid #fde68a;border-radius:6px;padding:10px 14px;">
                <p style="color:#92400e;font-size:13px;margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">This activation link expires in <strong>7 days</strong>. Please activate your account before it expires.</p>
              </td></tr>
            </table>

            <a href="{{activateUrl}}" style="display:inline-block;margin:20px 0 8px;padding:12px 28px;background-color:#7c3aed;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:600;font-size:15px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">Activate My Account</a>

            <p style="color:#475569;line-height:1.6;margin:12px 0;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">If the button above doesn't work, copy and paste this link into your browser:<br /><a href="{{activateUrl}}" style="color:#7c3aed;word-break:break-all;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">{{activateUrl}}</a></p>

            <p style="color:#475569;line-height:1.6;margin:12px 0;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">If you believe this invitation was sent in error, you can safely ignore this email.</p>
          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td align="center" bgcolor="#f8fafc" style="background-color:#f8fafc;padding:20px 40px;">
            <p style="color:#94a3b8;font-size:12px;margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">&copy; {{year}} TektonX Labs. All rights reserved.</p>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
