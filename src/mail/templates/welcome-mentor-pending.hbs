<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Application Received — TektonX</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" bgcolor="#f4f4f5" style="background-color:#f4f4f5;">
    <tr><td align="center" style="padding:40px 20px;">

      <table width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;background-color:#ffffff;border-radius:8px;overflow:hidden;">

        <!-- HEADER -->
        <tr>
          <td align="center" bgcolor="#0f172a" style="background-color:#0f172a;padding:28px 40px;">
            <img src="{{frontendUrl}}/logo-white-horizontal.svg" alt="TektonX" width="180" style="display:block;height:auto;" />
          </td>
        </tr>

        <!-- BODY -->
        <tr>
          <td style="padding:40px;background-color:#ffffff;">
            <h2 style="color:#0f172a;margin:0 0 8px 0;font-size:20px;font-weight:700;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">Application Received, {{name}}!</h2>
            <span style="display:inline-block;padding:6px 14px;background-color:#fef3c7;color:#92400e;border-radius:20px;font-size:13px;font-weight:600;margin:8px 0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">Pending Review</span>
            <p style="color:#475569;line-height:1.6;margin:12px 0;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">Thank you for applying to become a TektonX mentor. We've received your application and our team will review it carefully.</p>
            <p style="color:#475569;line-height:1.6;margin:12px 0;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">You'll receive another email once a decision has been made. This typically takes <strong>1&#8211;3 business days</strong>.</p>

            <table width="100%" cellpadding="0" cellspacing="0" style="margin:20px 0;">
              <tr><td bgcolor="#f5f3ff" style="background-color:#f5f3ff;border:1px solid #ddd6fe;border-radius:8px;padding:16px 20px;">
                <p style="color:#4c1d95;margin:0;font-size:14px;line-height:1.5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">In the meantime, you can log into your dashboard at any time to follow up on the status of your application.</p>
              </td></tr>
            </table>

            <a href="{{dashboardUrl}}" style="display:inline-block;margin:20px 0 8px;padding:12px 28px;background-color:#7c3aed;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:600;font-size:15px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">Go to My Dashboard</a>

            <p style="color:#475569;line-height:1.6;margin:12px 0;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">If you have any questions, feel free to reach us at <a href="mailto:tektonxlabs@gmail.com" style="color:#7c3aed;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">tektonxlabs@gmail.com</a>.</p>
          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td align="center" bgcolor="#f8fafc" style="background-color:#f8fafc;padding:20px 40px;">
            <p style="color:#94a3b8;font-size:12px;margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">&copy; {{year}} TektonX Labs. All rights reserved.</p>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
