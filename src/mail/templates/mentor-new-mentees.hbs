<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>New Mentee Assignment — TektonX</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" bgcolor="#f4f4f5" style="background-color:#f4f4f5;">
    <tr><td align="center" style="padding:40px 20px;">

      <table width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;background-color:#ffffff;border-radius:8px;overflow:hidden;">

        <!-- HEADER -->
        <tr>
          <td align="center" bgcolor="#0f172a" style="background-color:#0f172a;padding:28px 40px;">
            <img src="{{frontendUrl}}/logo-white-horizontal.svg" alt="TektonX" width="180" style="display:block;height:auto;" />
          </td>
        </tr>

        <!-- BODY -->
        <tr>
          <td style="padding:40px;background-color:#ffffff;">
            <h2 style="color:#0f172a;margin:0 0 8px 0;font-size:20px;font-weight:700;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">New mentee assignment, {{mentorName}}!</h2>
            <p style="color:#475569;line-height:1.6;margin:12px 0;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">The following mentee(s) have been assigned to you:</p>

            <table width="100%" cellpadding="0" cellspacing="0" style="margin:16px 0;">
              {{#each mentees}}
              <tr>
                <td bgcolor="#f8fafc" style="background-color:#f8fafc;border-radius:6px;padding:10px 14px;margin-bottom:8px;">
                  <table width="100%" cellpadding="0" cellspacing="0">
                    <tr>
                      <td><span style="font-weight:600;color:#0f172a;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">{{this.name}}</span></td>
                      <td align="right"><span style="color:#64748b;font-size:13px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">{{this.track}}</span></td>
                    </tr>
                  </table>
                </td>
              </tr>
              <tr><td height="8" style="font-size:0;line-height:0;">&nbsp;</td></tr>
              {{/each}}
            </table>

            <p style="color:#475569;line-height:1.6;margin:12px 0;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">Visit your dashboard to see their progress, schedule sessions, and share resources.</p>

            <a href="{{dashboardUrl}}" style="display:inline-block;margin:20px 0 8px;padding:12px 28px;background-color:#0ea5e9;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:600;font-size:15px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">Go to My Dashboard</a>
          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td align="center" bgcolor="#f8fafc" style="background-color:#f8fafc;padding:20px 40px;">
            <p style="color:#94a3b8;font-size:12px;margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">&copy; {{year}} TektonX Labs. All rights reserved.</p>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
