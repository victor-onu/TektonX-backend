<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Application Update — TektonX</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" bgcolor="#f4f4f5" style="background-color:#f4f4f5;">
    <tr><td align="center" style="padding:40px 20px;">

      <table width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;background-color:#ffffff;border-radius:8px;overflow:hidden;">

        <!-- HEADER -->
        <tr>
          <td align="center" bgcolor="#0f172a" style="background-color:#0f172a;padding:28px 40px;">
            <img src="{{frontendUrl}}/logo-white-horizontal.svg" alt="TektonX" width="180" style="display:block;height:auto;" />
          </td>
        </tr>

        <!-- BODY -->
        <tr>
          <td style="padding:40px;background-color:#ffffff;">
            <h2 style="color:#0f172a;margin:0 0 8px 0;font-size:20px;font-weight:700;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">Hi {{name}},</h2>
            <p style="color:#475569;line-height:1.6;margin:12px 0;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">Thank you for your interest in becoming a TektonX mentor. After careful review, we're unable to approve your application at this time.</p>

            {{#if reason}}
            <table width="100%" cellpadding="0" cellspacing="0" style="margin:16px 0;">
              <tr><td style="border-left:4px solid #fca5a5;background-color:#fef2f2;padding:12px 16px;border-radius:4px;">
                <p style="color:#7f1d1d;font-size:14px;margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;"><strong>Reason:</strong> {{reason}}</p>
              </td></tr>
            </table>
            {{/if}}

            <p style="color:#475569;line-height:1.6;margin:12px 0;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">We appreciate the time you took to apply and encourage you to re-apply in the future as our program grows. If you have any questions, please reach out to us at <a href="mailto:{{contactEmail}}" style="color:#7c3aed;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">{{contactEmail}}</a>.</p>
          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td align="center" bgcolor="#f8fafc" style="background-color:#f8fafc;padding:20px 40px;">
            <p style="color:#94a3b8;font-size:12px;margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">&copy; {{year}} TektonX Labs. All rights reserved.</p>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
